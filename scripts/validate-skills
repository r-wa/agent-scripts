#!/usr/bin/env python3
from __future__ import annotations

import re
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
SKILLS = ROOT / "skills"

FRONTMATTER = re.compile(r"^---\n(.*?)\n---\n", re.DOTALL)
NAME_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")


def parse_frontmatter(path: Path) -> dict[str, str]:
    text = path.read_text(encoding="utf-8")
    match = FRONTMATTER.match(text)
    if not match:
        raise ValueError("missing YAML front matter")

    data: dict[str, str] = {}
    for line in match.group(1).splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if ":" not in stripped:
            raise ValueError(f"bad front matter line: {line}")
        key, value = stripped.split(":", 1)
        data[key.strip()] = value.strip()
    return data


def validate_skill(skill_dir: Path) -> list[str]:
    errors: list[str] = []
    skill = skill_dir / "SKILL.md"

    if not skill.exists():
        return [f"{skill_dir.name}: missing SKILL.md"]

    try:
        frontmatter = parse_frontmatter(skill)
    except Exception as exc:
        return [f"{skill}: {exc}"]

    name = frontmatter.get("name", "")
    raw_description = frontmatter.get("description", "")
    description = raw_description.strip('"').strip("'")

    if not name:
        errors.append(f"{skill}: missing name")
    elif name != skill_dir.name:
        errors.append(f"{skill}: name must match folder name")
    elif not NAME_RE.match(name):
        errors.append(f"{skill}: name must be kebab-case")

    if not description:
        errors.append(f"{skill}: missing description")
    elif not (raw_description.startswith('"') and raw_description.endswith('"')):
        errors.append(f"{skill}: description must be double-quoted")
    elif len(description) > 140:
        errors.append(f"{skill}: description too long; keep routing terse")

    scripts_dir = skill_dir / "scripts"
    if scripts_dir.exists():
        for script in sorted(path for path in scripts_dir.iterdir() if path.is_file()):
            if not script.stat().st_mode & 0o111:
                errors.append(f"{script}: script must be executable")

    return errors


def main() -> int:
    if not SKILLS.exists():
        print("skills directory is missing", file=sys.stderr)
        return 1

    errors: list[str] = []
    for skill_dir in sorted(SKILLS.iterdir()):
        if skill_dir.is_dir():
            errors.extend(validate_skill(skill_dir))

    if errors:
        print("\n".join(errors), file=sys.stderr)
        return 1

    print("ok")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
